# =============================================================================
# Culture Circle Inventory — environment variables
# Copy to `.env` for local dev. On Vercel, paste each value into
# Project → Settings → Environment Variables.
# =============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string

# ── Database ─────────────────────────────────────────────────────────────────
# On Vercel/Neon/Supabase use a single connection string. Locally you can
# instead set the DB_* fields below and leave DATABASE_URL empty.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Local fallback (only used if DATABASE_URL is empty)
DB_NAME=culture_circle_inventory
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ── Google Sheets sync ───────────────────────────────────────────────────────
# Paste the *full JSON contents* of credentials.json and token.json as
# single-line strings. On Vercel: Settings → Environment Variables → "Add" →
# paste the JSON in the value field (Vercel handles the newlines fine).
#
# Generate token.json once locally by running:
#   python tools/google_sheets.py read 1ruCsGpMN58hiNaJosSezZ-1ykesnRvXKzmaXFYPWApA "'PLAINS STOCK'!A1:B2"
#
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","project_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"...","redirect_uris":["http://localhost"]}}
GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/spreadsheets"],"universe_domain":"googleapis.com","account":"","expiry":"2026-05-01T00:00:00Z"}

# Optional: override the inventory sheet ID / range (defaults match the
# Culture Circle Nangloi warehouse sheet).
SHEET_ID=1ruCsGpMN58hiNaJosSezZ-1ykesnRvXKzmaXFYPWApA
SHEET_RANGE='PLAINS STOCK'!A1:H

# =============================================================================
# Shopify — one ACCESS_TOKEN + DOMAIN per connected store
# =============================================================================
# Each store's `<PREFIX>` must match a value in config.SHOPIFY_STORE_PREFIXES.
# CLIENT_ID / CLIENT_SECRET are only needed if you re-run the install OAuth
# flow; the app at runtime only reads ACCESS_TOKEN + DOMAIN.

# House of Piere Eric
PIEREERIC_SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIEREERIC_SHOPIFY_DOMAIN=piereeric.myshopify.com

